# RN 0.84+ ships React-Core as a prebuilt binary by default, which is incompatible
# with @react-native-firebase static frameworks. Disable prebuilt RN until upstream fixes land.
# https://github.com/invertase/react-native-firebase/issues/8883
ENV['RCT_USE_PREBUILT_RNCORE'] = '0'

# Transform this into a `node_require` generic function:
def node_require(script)
  # Resolve script with node to allow for hoisting
  require Pod::Executable.execute_command('node', ['-p',
    "require.resolve(
      '#{script}',
      {paths: [process.argv[1]]},
    )", __dir__]).strip
end

# Use it to require both react-native's and this package's scripts:
node_require('react-native/scripts/react_native_pods.rb')
node_require('react-native-permissions/scripts/setup.rb')

platform :ios, '15.1'
prepare_react_native_project!

# Convert all permission pods into static libraries
# https://github.com/zoontek/react-native-permissions/issues/469#issuecomment-666223083
pre_install do |installer|
  installer.pod_targets.each do |pod|
    # RN 0.84+ ships prebuilt React-Core; RNFB pods must be static libraries to avoid
    # "include of non-modular header inside framework module" errors.
    # https://github.com/invertase/react-native-firebase/issues/8883
    if pod.name.eql?('RNPermissions') || pod.name.start_with?('Permission-') || pod.name.start_with?('RNFB')
      def pod.build_type;
        Pod::BuildType.static_library # >= 1.9
      end
    end
  end
end

# ⬇️ uncomment the permissions you need
setup_permissions([
  # 'AppTrackingTransparency',
  # 'Bluetooth',
  # 'Calendars',
  # 'CalendarsWriteOnly',
  'Camera',
  # 'Contacts',
  # 'FaceID',
  # 'LocationAccuracy',
  # 'LocationAlways',
  'LocationWhenInUse',
  # 'MediaLibrary',
  # 'Microphone',
  # 'Motion',
  'Notifications',
  # 'PhotoLibrary',
  # 'PhotoLibraryAddOnly',
  # 'Reminders',
  # 'Siri',
  # 'SpeechRecognition',
  # 'StoreKit',
])

target 'PassCulture' do
  config = use_native_modules!
  use_frameworks! :linkage => :static # Required by react-native-firebase v15+
  $RNFirebaseAsStaticFramework = true # https://rnfirebase.io/#altering-cocoapods-to-use-frameworks
  
  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # Third party deps podspec link, to include if 0.60 autolinking not supported

  pod 'FirebaseCore', :modular_headers => true
  pod 'GoogleUtilities', :modular_headers => true
  pod 'BatchFirebaseDispatcher'

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )
  end
end