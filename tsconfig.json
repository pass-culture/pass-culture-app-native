{
  "compilerOptions": {
    "paths": {
      "*": [
        "./src/*",
        "./*"
      ] // if you change this line, check this doc https://github.com/pass-culture/pass-culture-app-native/blob/5ff5fba596244a759d60f8c9cdb67d56ac86a1a7/doc/development/alias.md
    },
    "types": ["jest"],
    "allowJs": true,
    "isolatedModules": true,
    "jsx": "react",
    "lib": [
      "es2022",
      "dom",
      "esnext"
    ],
    "noEmit": true,
    "noImplicitAny": false,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "removeComments": true,
  },
  "exclude": [
    "build/**",
    "dist/**",
    "maestro/**",
    "node_modules/**",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js",
    "jest.web.config.js",
    "react-native.config.js",
    "rn-cli.config.js",
    "coverage/**",
    "./server/**",
    "doc/**"
  ],
  "extends": "@react-native/typescript-config"
}
